{
    "compilerOptions": {
        "target": "ES2019",
        "module": "None",
        "lib": ["ES2019"],
        "outDir": "gas",
        "rootDir": "src",
        "strict": false,
        "alwaysStrict": false,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "removeComments": false,
        "declaration": false,
        "typeRoots": ["./node_modules/@types"]
    },
    "include": ["src/**/*.ts"]
}
